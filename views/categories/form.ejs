<%- include('layout/header', { title: isEdit ? 'Edit Kategori' : 'Buat Kategori' }) %>
<%- include('layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800">
            <% if (isEdit) { %>
                Edit Kategori
            <% } else { %>
                Buat Kategori Baru
            <% } %>
        </h1>
        <p class="text-gray-600">Organisir transaksi Anda dengan kategori</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-lg shadow p-8 max-w-2xl mx-auto">
        <!-- Error Alert -->
        <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
            <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                <p class="text-red-600 text-sm font-medium mb-2"><i class="fas fa-exclamation-circle mr-2"></i>Terjadi Kesalahan</p>
                <% errors.forEach(error => { %>
                    <p class="text-red-500 text-xs">• <%= error.message %></p>
                <% }); %>
            </div>
        <% } %>

        <form method="POST" action="<% if (isEdit) { %>/categories/<%= category.id %>/update<% } else { %>/categories/create<% } %>" class="space-y-6">
            <!-- Nama Kategori -->
            <div>
                <label for="nama_kategori" class="block text-sm font-medium text-gray-700 mb-2">Nama Kategori</label>
                <input type="text" id="nama_kategori" name="nama_kategori" required
                    value="<% if (isEdit) { %><%= category.nama_kategori %><% } %>"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="Misalnya: Makanan, Transportasi, Gaji, dsb">
            </div>

            <!-- Tipe Kategori -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-3">Tipe Kategori</label>
                <div class="grid grid-cols-2 gap-4">
                    <label class="flex items-center p-4 border-2 rounded-lg cursor-pointer transition" id="income-label">
                        <input type="radio" name="tipe" value="income" 
                            <%= (isEdit && category.tipe === 'income') || (!isEdit && query.tipe === 'income') ? 'checked' : '' %>
                            class="form-radio" onchange="updateForm()">
                        <span class="ml-3 flex items-center">
                            <i class="fas fa-arrow-up text-green-600 mr-2"></i>
                            <span class="font-medium">Pemasukan</span>
                        </span>
                    </label>
                    <label class="flex items-center p-4 border-2 rounded-lg cursor-pointer transition" id="expense-label">
                        <input type="radio" name="tipe" value="expense" 
                            <%= (isEdit && category.tipe === 'expense') || (!isEdit && query.tipe === 'expense') ? 'checked' : '' %>
                            class="form-radio" onchange="updateForm()">
                        <span class="ml-3 flex items-center">
                            <i class="fas fa-arrow-down text-red-600 mr-2"></i>
                            <span class="font-medium">Pengeluaran</span>
                        </span>
                    </label>
                </div>
            </div>

            <!-- Warna Kategori -->
            <div>
                <label for="warna" class="block text-sm font-medium text-gray-700 mb-2">Warna Kategori</label>
                <div class="flex items-center space-x-4">
                    <input type="color" id="warna" name="warna" required
                        value="<% if (isEdit) { %><%= category.warna %><% } else { %>#4F46E5<% } %>"
                        class="w-16 h-16 border border-gray-300 rounded-lg cursor-pointer">
                    <div>
                        <p class="text-xs text-gray-500 uppercase font-medium mb-1">Preview Warna</p>
                        <div class="flex space-x-2">
                            <div id="colorPreview" class="w-12 h-12 rounded-lg border-2 border-gray-200" 
                                style="background-color: <% if (isEdit) { %><%= category.warna %><% } else { %>#4F46E5<% } %>"></div>
                            <p class="text-sm text-gray-600 self-center" id="colorCode">
                                <% if (isEdit) { %><%= category.warna %><% } else { %>#4F46E5<% } %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Popular Colors -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-3">Warna Populer</label>
                <div class="grid grid-cols-8 gap-2">
                    <% const colors = ['#FF6B6B', '#FFA500', '#FFD93D', '#6BCB77', '#4D96FF', '#9B59B6', '#E74C3C', '#1ABC9C']; %>
                    <% colors.forEach(color => { %>
                        <button type="button" class="w-10 h-10 rounded-lg border-2 border-gray-300 hover:border-gray-400 cursor-pointer transition" 
                            style="background-color: <%= color %>"
                            onclick="setColor('<%= color %>')"></button>
                    <% }); %>
                </div>
            </div>

            <!-- Buttons -->
            <div class="flex justify-end space-x-4 pt-6 border-t">
                <a href="/categories" class="px-6 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 font-medium transition">
                    Batal
                </a>
                <button type="submit" class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium transition">
                    <% if (isEdit) { %>
                        <i class="fas fa-save mr-2"></i>Simpan Perubahan
                    <% } else { %>
                        <i class="fas fa-plus mr-2"></i>Buat Kategori
                    <% } %>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    const colorInput = document.getElementById('warna');
    const colorPreview = document.getElementById('colorPreview');
    const colorCode = document.getElementById('colorCode');

    colorInput.addEventListener('change', function() {
        updateColorPreview();
    });

    function setColor(color) {
        colorInput.value = color;
        updateColorPreview();
    }

    function updateColorPreview() {
        const color = colorInput.value;
        colorPreview.style.backgroundColor = color;
        colorCode.textContent = color.toUpperCase();
    }

    function updateForm() {
        const tipe = document.querySelector('input[name="tipe"]:checked').value;
        const incomeLabel = document.getElementById('income-label');
        const expenseLabel = document.getElementById('expense-label');
        
        if (tipe === 'income') {
            incomeLabel.classList.add('border-green-500', 'bg-green-50');
            incomeLabel.classList.remove('border-gray-300');
            expenseLabel.classList.remove('border-red-500', 'bg-red-50');
            expenseLabel.classList.add('border-gray-300');
        } else {
            expenseLabel.classList.add('border-red-500', 'bg-red-50');
            expenseLabel.classList.remove('border-gray-300');
            incomeLabel.classList.remove('border-green-500', 'bg-green-50');
            incomeLabel.classList.add('border-gray-300');
        }
    }

    // Initialize on load
    window.addEventListener('load', function() {
        updateForm();
    });
</script>

<%- include('layout/footer') %>
