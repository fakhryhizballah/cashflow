<%- include('layout/header', { title: 'Kesalahan Server' }) %>

<!-- Error Container -->
<div class="min-h-screen bg-gradient-to-br from-red-500 to-red-600 flex items-center justify-center px-4">
    <div class="w-full max-w-md text-center">
        <!-- Error Code -->
        <div class="text-8xl font-bold text-white mb-4 opacity-20">500</div>

        <!-- Error Message -->
        <div class="bg-white rounded-lg shadow-xl p-8">
            <i class="fas fa-server text-6xl text-red-500 mb-4"></i>
            
            <h1 class="text-4xl font-bold text-gray-800 mb-2">Kesalahan Server Internal</h1>
            <p class="text-gray-600 mb-6">
                Maaf, terjadi kesalahan pada server. Tim kami telah diberitahu dan akan segera memperbaikinya.
            </p>

            <!-- Error Details -->
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="bg-gray-50 rounded-lg p-4 mb-6 text-left">
                    <p class="text-xs text-gray-600 uppercase font-medium mb-1">Pesan Error</p>
                    <p class="text-sm text-gray-700 font-mono"><%= message %></p>
                </div>
            <% } %>

            <!-- Stack Trace (Development Only) -->
            <% if (typeof stack !== 'undefined' && stack && process.env.NODE_ENV !== 'production') { %>
                <div class="bg-gray-900 rounded-lg p-4 mb-6 text-left max-h-40 overflow-y-auto">
                    <p class="text-xs text-gray-400 uppercase font-medium mb-1">Stack Trace</p>
                    <p class="text-xs text-gray-300 font-mono whitespace-pre-wrap"><%= stack %></p>
                </div>
            <% } %>

            <!-- Action Buttons -->
            <div class="space-y-3">
                <a href="/dashboard" class="block w-full px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition">
                    <i class="fas fa-home mr-2"></i>Kembali ke Dashboard
                </a>
                <a href="javascript:location.reload()" class="block w-full px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium rounded-lg transition">
                    <i class="fas fa-refresh mr-2"></i>Muat Ulang Halaman
                </a>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center mt-8 text-white text-sm opacity-75">
            <p>Jika masalah berlanjut, hubungi support kami</p>
            <p>Cash Flow Management © 2026</p>
        </div>
    </div>
</div>

<%- include('layout/footer') %>
