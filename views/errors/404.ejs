<%- include('layout/header', { title: 'Halaman Tidak Ditemukan' }) %>

<!-- Error Container -->
<div class="min-h-screen bg-gradient-to-br from-indigo-500 to-indigo-600 flex items-center justify-center px-4">
    <div class="w-full max-w-md text-center">
        <!-- Error Code -->
        <div class="text-8xl font-bold text-white mb-4 opacity-20">404</div>

        <!-- Error Message -->
        <div class="bg-white rounded-lg shadow-xl p-8">
            <i class="fas fa-exclamation-triangle text-6xl text-yellow-500 mb-4"></i>
            
            <h1 class="text-4xl font-bold text-gray-800 mb-2">Halaman Tidak Ditemukan</h1>
            <p class="text-gray-600 mb-6">
                Maaf, halaman yang Anda cari tidak ada atau telah dipindahkan.
            </p>

            <!-- Error Details -->
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="bg-gray-50 rounded-lg p-4 mb-6 text-left">
                    <p class="text-xs text-gray-600 uppercase font-medium mb-1">Pesan Error</p>
                    <p class="text-sm text-gray-700"><%= message %></p>
                </div>
            <% } %>

            <!-- Action Buttons -->
            <div class="space-y-3">
                <a href="/dashboard" class="block w-full px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition">
                    <i class="fas fa-home mr-2"></i>Kembali ke Dashboard
                </a>
                <a href="javascript:history.back()" class="block w-full px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium rounded-lg transition">
                    <i class="fas fa-arrow-left mr-2"></i>Kembali
                </a>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center mt-8 text-white text-sm opacity-75">
            <p>Cash Flow Management © 2026</p>
        </div>
    </div>
</div>

<%- include('layout/footer') %>
