<%- include('../layout/header', { title: 'Ubah Password' }) %>
<%- include('../layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800">Ubah Password</h1>
        <p class="text-gray-600">Perbarui password akun Anda untuk keamanan yang lebih baik</p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-lg shadow p-8 max-w-2xl mx-auto">
        <!-- Success Alert -->
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
                <p class="text-green-600 text-sm font-medium">
                    <i class="fas fa-check-circle mr-2"></i><%= success %>
                </p>
            </div>
        <% } %>

        <!-- Error Alert -->
        <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
            <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                <p class="text-red-600 text-sm font-medium mb-2"><i class="fas fa-exclamation-circle mr-2"></i>Terjadi Kesalahan</p>
                <% errors.forEach(error => { %>
                    <p class="text-red-500 text-xs">• <%= error.message %></p>
                <% }); %>
            </div>
        <% } %>

        <form method="POST" action="/profile/change-password" class="space-y-6">
            <!-- Current Password -->
            <div>
                <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-2">Password Saat Ini</label>
                <input type="password" id="currentPassword" name="currentPassword" required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="••••••••">
            </div>

            <!-- New Password -->
            <div>
                <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-2">Password Baru</label>
                <input type="password" id="newPassword" name="newPassword" required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="••••••••">
                <p class="text-xs text-gray-500 mt-1">Minimal 6 karakter</p>
            </div>

            <!-- Confirm New Password -->
            <div>
                <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-2">Konfirmasi Password Baru</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="••••••••">
            </div>

            <!-- Password Strength Indicator -->
            <div>
                <p class="text-xs text-gray-500 font-medium mb-2">Kekuatan Password</p>
                <div class="flex space-x-1">
                    <div id="strength-bar-1" class="flex-1 h-1 bg-gray-300 rounded-full"></div>
                    <div id="strength-bar-2" class="flex-1 h-1 bg-gray-300 rounded-full"></div>
                    <div id="strength-bar-3" class="flex-1 h-1 bg-gray-300 rounded-full"></div>
                    <div id="strength-bar-4" class="flex-1 h-1 bg-gray-300 rounded-full"></div>
                </div>
                <p id="strength-text" class="text-xs text-gray-600 mt-1">-</p>
            </div>

            <!-- Password Requirements -->
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                <p class="text-sm font-medium text-blue-800 mb-2"><i class="fas fa-info-circle mr-2"></i>Persyaratan Password</p>
                <ul class="text-xs text-blue-700 space-y-1">
                    <li id="req-length"><i class="fas fa-circle-notch mr-1"></i>Minimal 6 karakter</li>
                    <li id="req-uppercase"><i class="fas fa-circle-notch mr-1"></i>Setidaknya 1 huruf besar</li>
                    <li id="req-lowercase"><i class="fas fa-circle-notch mr-1"></i>Setidaknya 1 huruf kecil</li>
                    <li id="req-number"><i class="fas fa-circle-notch mr-1"></i>Setidaknya 1 angka</li>
                </ul>
            </div>

            <!-- Buttons -->
            <div class="flex justify-end space-x-4 pt-6 border-t">
                <a href="/profile" class="px-6 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 font-medium transition">
                    Batal
                </a>
                <button type="submit" class="px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium transition">
                    <i class="fas fa-lock mr-2"></i>Ubah Password
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    const newPasswordInput = document.getElementById('newPassword');
    const strengthBars = document.querySelectorAll('[id^="strength-bar-"]');
    const strengthText = document.getElementById('strength-text');
    
    // Password requirements
    const requirements = {
        length: document.getElementById('req-length'),
        uppercase: document.getElementById('req-uppercase'),
        lowercase: document.getElementById('req-lowercase'),
        number: document.getElementById('req-number')
    };

    newPasswordInput.addEventListener('input', function() {
        const password = this.value;
        let strength = 0;

        // Check requirements
        const hasLength = password.length >= 6;
        const hasUppercase = /[A-Z]/.test(password);
        const hasLowercase = /[a-z]/.test(password);
        const hasNumber = /\d/.test(password);

        // Update requirement indicators
        updateRequirement(requirements.length, hasLength);
        updateRequirement(requirements.uppercase, hasUppercase);
        updateRequirement(requirements.lowercase, hasLowercase);
        updateRequirement(requirements.number, hasNumber);

        // Calculate strength
        if (hasLength) strength++;
        if (hasUppercase) strength++;
        if (hasLowercase) strength++;
        if (hasNumber) strength++;

        // Update strength bars
        strengthBars.forEach((bar, index) => {
            bar.style.backgroundColor = '#D1D5DB';
            if (index < strength) {
                if (strength <= 1) {
                    bar.style.backgroundColor = '#EF4444'; // Red
                } else if (strength <= 2) {
                    bar.style.backgroundColor = '#F59E0B'; // Orange
                } else if (strength <= 3) {
                    bar.style.backgroundColor = '#10B981'; // Green
                } else {
                    bar.style.backgroundColor = '#059669'; // Dark Green
                }
            }
        });

        // Update strength text
        if (strength === 0) {
            strengthText.textContent = '-';
            strengthText.style.color = '#6B7280';
        } else if (strength === 1) {
            strengthText.textContent = 'Lemah';
            strengthText.style.color = '#EF4444';
        } else if (strength === 2) {
            strengthText.textContent = 'Sedang';
            strengthText.style.color = '#F59E0B';
        } else if (strength === 3) {
            strengthText.textContent = 'Kuat';
            strengthText.style.color = '#10B981';
        } else {
            strengthText.textContent = 'Sangat Kuat';
            strengthText.style.color = '#059669';
        }
    });

    function updateRequirement(element, isMet) {
        if (isMet) {
            element.classList.add('text-green-600');
            element.querySelector('i').className = 'fas fa-check-circle mr-1';
        } else {
            element.classList.remove('text-green-600');
            element.querySelector('i').className = 'fas fa-circle-notch mr-1';
        }
    }
</script>

<%- include('../layout/footer') %>
