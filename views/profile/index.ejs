<%- include('../layout/header', { title: 'Profile' }) %>
<%- include('../layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800">Profile Anda</h1>
        <p class="text-gray-600">Kelola informasi akun Anda</p>
    </div>

    <!-- Profile Card -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Sidebar Info -->
        <div class="bg-white rounded-lg shadow p-6">
            <div class="text-center mb-6">
                <div class="w-24 h-24 bg-indigo-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-user text-4xl text-white"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-800"><%= user.username %></h2>
                <p class="text-gray-600"><%= user.email %></p>
            </div>

            <div class="space-y-4 pt-6 border-t">
                <div>
                    <p class="text-xs text-gray-500 uppercase font-medium mb-1">Member Sejak</p>
                    <p class="text-sm text-gray-700"><%= new Date(user.createdAt).toLocaleDateString('id-ID') %></p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-medium mb-1">Terakhir Diperbarui</p>
                    <p class="text-sm text-gray-700"><%= new Date(user.updatedAt).toLocaleDateString('id-ID') %></p>
                </div>
            </div>

            <div class="mt-6 pt-6 border-t">
                <a href="/profile/edit" class="block w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-center font-medium transition">
                    <i class="fas fa-edit mr-2"></i>Edit Profile
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Account Information -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-xl font-bold text-gray-800 mb-6">Informasi Akun</h2>
                
                <div class="space-y-4">
                    <div>
                        <label class="text-xs text-gray-500 uppercase font-medium">Username</label>
                        <p class="text-lg text-gray-800 font-medium"><%= user.username %></p>
                    </div>
                    <div>
                        <label class="text-xs text-gray-500 uppercase font-medium">Email</label>
                        <p class="text-lg text-gray-800 font-medium"><%= user.email %></p>
                    </div>
                </div>
            </div>

            <!-- Statistics -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-xl font-bold text-gray-800 mb-6">Statistik Akun</h2>
                
                <div class="grid grid-cols-3 gap-4">
                    <div class="text-center p-4 bg-indigo-50 rounded-lg">
                        <p class="text-2xl font-bold text-indigo-600"><%= stats.totalAssets || 0 %></p>
                        <p class="text-xs text-gray-600 mt-1">Total Aset</p>
                    </div>
                    <div class="text-center p-4 bg-green-50 rounded-lg">
                        <p class="text-2xl font-bold text-green-600"><%= stats.totalTransactions || 0 %></p>
                        <p class="text-xs text-gray-600 mt-1">Total Transaksi</p>
                    </div>
                    <div class="text-center p-4 bg-purple-50 rounded-lg">
                        <p class="text-2xl font-bold text-purple-600"><%= stats.totalCategories || 0 %></p>
                        <p class="text-xs text-gray-600 mt-1">Total Kategori</p>
                    </div>
                </div>
            </div>

            <!-- Security Settings -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-xl font-bold text-gray-800 mb-6">Keamanan</h2>
                
                <div class="space-y-4">
                    <p class="text-gray-600 text-sm mb-4">Kelola keamanan akun Anda</p>
                    <a href="/profile/change-password" class="block p-4 bg-gray-50 hover:bg-gray-100 rounded-lg transition">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="font-medium text-gray-800">Ubah Password</p>
                                <p class="text-xs text-gray-600 mt-1">Perbarui password akun Anda</p>
                            </div>
                            <i class="fas fa-chevron-right text-gray-400"></i>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="bg-red-50 border border-red-200 rounded-lg p-6">
                <h2 class="text-xl font-bold text-red-800 mb-4">Zona Berbahaya</h2>
                <p class="text-sm text-red-700 mb-4">Tindakan berikut tidak dapat dibatalkan. Harap hati-hati.</p>
                
                <button onclick="deleteAccount()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition">
                    <i class="fas fa-trash mr-2"></i>Hapus Akun
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Account Modal -->
<div id="deleteAccountModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
        <div class="bg-gradient-to-r from-red-500 to-red-600 px-6 py-4">
            <h2 class="text-xl font-bold text-white">Hapus Akun</h2>
        </div>
        <div class="p-6">
            <p class="text-gray-700 mb-4">
                Apakah Anda yakin ingin menghapus akun ini? Semua data Anda akan dihapus secara permanen dan tidak dapat dipulihkan.
            </p>
            <p class="text-sm text-gray-600 mb-6">
                Masukkan password Anda untuk mengkonfirmasi:
            </p>
            <input type="password" id="deletePassword" placeholder="Password Anda" 
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 outline-none mb-6">
            
            <div class="flex justify-end space-x-3">
                <button onclick="closeDeleteAccountModal()" class="px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
                    Batal
                </button>
                <button onclick="confirmDeleteAccount()" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg">
                    Hapus Akun
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function deleteAccount() {
        document.getElementById('deleteAccountModal').classList.remove('hidden');
        document.getElementById('deletePassword').focus();
    }

    function closeDeleteAccountModal() {
        document.getElementById('deleteAccountModal').classList.add('hidden');
        document.getElementById('deletePassword').value = '';
    }

    async function confirmDeleteAccount() {
        const password = document.getElementById('deletePassword').value;
        
        if (!password) {
            alert('Masukkan password Anda');
            return;
        }

        try {
            const response = await fetch('/api/auth/delete-account', {
                method: 'DELETE',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ password })
            });

            const data = await response.json();

            if (response.ok) {
                alert('Akun Anda telah dihapus');
                window.location.href = '/auth/login';
            } else {
                alert(data.error || 'Terjadi kesalahan');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Terjadi kesalahan');
        }
    }

    // Close modal when clicking outside
    document.getElementById('deleteAccountModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeDeleteAccountModal();
        }
    });
</script>

<%- include('../layout/footer') %>
