<%- include('layout/header', { title: 'Dashboard' }) %>
<%- include('layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800 mb-2">Dashboard</h1>
        <p class="text-gray-600">Selamat datang, <%= user.username %>! Berikut ringkasan keuangan Anda.</p>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Total Assets -->
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-indigo-600">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">Total Aset</p>
                    <p class="text-3xl font-bold text-gray-800 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(stats.totalAssets || 0) %>
                    </p>
                </div>
                <div class="text-indigo-600 text-4xl opacity-20">
                    <i class="fas fa-wallet"></i>
                </div>
            </div>
        </div>

        <!-- This Month Income -->
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">Pemasukan Bulan Ini</p>
                    <p class="text-3xl font-bold text-green-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(stats.monthlyIncome || 0) %>
                    </p>
                </div>
                <div class="text-green-500 text-4xl opacity-20">
                    <i class="fas fa-arrow-up"></i>
                </div>
            </div>
        </div>

        <!-- This Month Expense -->
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-red-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">Pengeluaran Bulan Ini</p>
                    <p class="text-3xl font-bold text-red-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(stats.monthlyExpense || 0) %>
                    </p>
                </div>
                <div class="text-red-500 text-4xl opacity-20">
                    <i class="fas fa-arrow-down"></i>
                </div>
            </div>
        </div>

        <!-- Net Balance -->
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-amber-500">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-sm font-medium">Saldo Bersih</p>
                    <p class="text-3xl font-bold text-amber-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format((stats.monthlyIncome || 0) - (stats.monthlyExpense || 0)) %>
                    </p>
                </div>
                <div class="text-amber-500 text-4xl opacity-20">
                    <i class="fas fa-chart-line"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        <!-- Assets Summary -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-xl font-bold text-gray-800">Daftar Aset</h2>
                    <a href="/assets" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">
                        Lihat Semua <i class="fas fa-arrow-right ml-1"></i>
                    </a>
                </div>

                <div class="space-y-3">
                    <% if (typeof assets !== 'undefined' && assets && assets.length > 0) { %>
                        <% assets.slice(0, 5).forEach(asset => { %>
                            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                                        <i class="fas fa-university text-indigo-600"></i>
                                    </div>
                                    <div>
                                        <p class="font-medium text-gray-800"><%= asset.nama_aset %></p>
                                        <p class="text-xs text-gray-500"><%= asset.tipe_aset %></p>
                                    </div>
                                </div>
                                <p class="font-semibold text-gray-800">
                                    <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(asset.saldo) %>
                                </p>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p class="text-gray-500 text-center py-8">Belum ada aset. <a href="/assets" class="text-indigo-600 hover:text-indigo-700">Buat aset baru</a></p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-6">Aksi Cepat</h2>
            <div class="space-y-3">
                <a href="/transactions/create" class="block p-4 bg-gradient-to-r from-indigo-500 to-indigo-600 text-white rounded-lg hover:shadow-lg transition text-center font-medium">
                    <i class="fas fa-plus mr-2"></i>Transaksi Baru
                </a>
                <a href="/assets/create" class="block p-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg hover:shadow-lg transition text-center font-medium">
                    <i class="fas fa-plus mr-2"></i>Aset Baru
                </a>
                <a href="/categories/create" class="block p-4 bg-gradient-to-r from-green-500 to-green-600 text-white rounded-lg hover:shadow-lg transition text-center font-medium">
                    <i class="fas fa-plus mr-2"></i>Kategori Baru
                </a>
                <a href="/reports" class="block p-4 bg-gradient-to-r from-amber-500 to-amber-600 text-white rounded-lg hover:shadow-lg transition text-center font-medium">
                    <i class="fas fa-chart-pie mr-2"></i>Lihat Laporan
                </a>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-gray-800">Transaksi Terbaru</h2>
            <a href="/transactions" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">
                Lihat Semua <i class="fas fa-arrow-right ml-1"></i>
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Tanggal</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Kategori</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Aset</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Tipe</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase">Jumlah</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof transactions !== 'undefined' && transactions && transactions.length > 0) { %>
                        <% transactions.slice(0, 10).forEach(tx => { %>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    <%= new Date(tx.tanggal).toLocaleDateString('id-ID') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700"><%= tx.Category?.nama_kategori || '-' %></td>
                                <td class="px-6 py-4 text-sm text-gray-700"><%= tx.Asset?.nama_aset || '-' %></td>
                                <td class="px-6 py-4 text-sm">
                                    <% if (tx.tipe === 'income') { %>
                                        <span class="inline-block px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-medium">Pemasukan</span>
                                    <% } else { %>
                                        <span class="inline-block px-2 py-1 bg-red-100 text-red-800 rounded text-xs font-medium">Pengeluaran</span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-right font-semibold">
                                    <% if (tx.tipe === 'income') { %>
                                        <span class="text-green-600">+<%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(tx.jumlah) %></span>
                                    <% } else { %>
                                        <span class="text-red-600">-<%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(tx.jumlah) %></span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                                Belum ada transaksi
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('layout/footer') %>
