<%- include('../layout/header', { title: 'Laporan' }) %>
<%- include('../layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800">Laporan Keuangan</h1>
        <p class="text-gray-600">Analisis keuangan Anda secara detail</p>
    </div>

    <!-- Report Type Selection -->
    <div class="mb-8 flex space-x-4">
        <a href="/reports?type=monthly" class="px-6 py-3 <%= reportType === 'monthly' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> rounded-lg font-medium transition hover:shadow-lg">
            <i class="fas fa-calendar-days mr-2"></i>Laporan Bulanan
        </a>
        <a href="/reports?type=yearly" class="px-6 py-3 <%= reportType === 'yearly' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-700 border border-gray-300' %> rounded-lg font-medium transition hover:shadow-lg">
            <i class="fas fa-calendar-year mr-2"></i>Laporan Tahunan
        </a>
    </div>

    <% if (reportType === 'monthly') { %>
        <!-- Monthly Report -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
            <!-- Select Month -->
            <div class="lg:col-span-1">
                <form method="GET" action="/reports" class="space-y-4">
                    <input type="hidden" name="type" value="monthly">
                    <div>
                        <label for="year" class="block text-sm font-medium text-gray-700 mb-2">Tahun</label>
                        <select id="year" name="year" onchange="this.form.submit()"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
                            <% for (let y = new Date().getFullYear() - 5; y <= new Date().getFullYear(); y++) { %>
                                <option value="<%= y %>" <%= selectedYear === y ? 'selected' : '' %>><%= y %></option>
                            <% } %>
                        </select>
                    </div>
                    <div>
                        <label for="month" class="block text-sm font-medium text-gray-700 mb-2">Bulan</label>
                        <select id="month" name="month" onchange="this.form.submit()"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
                            <% const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']; %>
                            <% months.forEach((m, i) => { %>
                                <option value="<%= i + 1 %>" <%= selectedMonth === i + 1 ? 'selected' : '' %>><%= m %></option>
                            <% }); %>
                        </select>
                    </div>
                </form>
            </div>

            <!-- Summary Cards -->
            <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Income -->
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
                    <p class="text-gray-600 text-sm font-medium">Pemasukan</p>
                    <p class="text-2xl font-bold text-green-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(report.income || 0) %>
                    </p>
                </div>

                <!-- Expense -->
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-red-500">
                    <p class="text-gray-600 text-sm font-medium">Pengeluaran</p>
                    <p class="text-2xl font-bold text-red-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(report.expense || 0) %>
                    </p>
                </div>

                <!-- Net -->
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-indigo-600">
                    <p class="text-gray-600 text-sm font-medium">Saldo Bersih</p>
                    <p class="text-2xl font-bold text-indigo-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format((report.income || 0) - (report.expense || 0)) %>
                    </p>
                </div>
            </div>
        </div>

        <!-- Category Breakdown -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Income by Category -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-bold text-gray-800 mb-6">Pemasukan per Kategori</h2>
                <% if (report.byCategory && Object.keys(report.byCategory).length > 0) { %>
                    <div class="space-y-3">
                        <% Object.entries(report.byCategory).forEach(([category, data]) => { %>
                            <% if (data.income > 0) { %>
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                    <span class="font-medium text-gray-800"><%= category %></span>
                                    <span class="text-green-600 font-semibold">
                                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(data.income) %>
                                    </span>
                                </div>
                            <% } %>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">Tidak ada pemasukan di bulan ini</p>
                <% } %>
            </div>

            <!-- Expense by Category -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-bold text-gray-800 mb-6">Pengeluaran per Kategori</h2>
                <% if (report.byCategory && Object.keys(report.byCategory).length > 0) { %>
                    <div class="space-y-3">
                        <% Object.entries(report.byCategory).forEach(([category, data]) => { %>
                            <% if (data.expense > 0) { %>
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                    <span class="font-medium text-gray-800"><%= category %></span>
                                    <span class="text-red-600 font-semibold">
                                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(data.expense) %>
                                    </span>
                                </div>
                            <% } %>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p class="text-gray-500 text-center py-8">Tidak ada pengeluaran di bulan ini</p>
                <% } %>
            </div>
        </div>

    <% } else { %>
        <!-- Yearly Report -->
        <div class="space-y-6">
            <!-- Select Year -->
            <div class="bg-white rounded-lg shadow p-6 mb-8">
                <form method="GET" action="/reports" class="flex items-end gap-4">
                    <input type="hidden" name="type" value="yearly">
                    <div class="flex-1">
                        <label for="year-select" class="block text-sm font-medium text-gray-700 mb-2">Pilih Tahun</label>
                        <select id="year-select" name="year" onchange="this.form.submit()"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
                            <% for (let y = new Date().getFullYear() - 5; y <= new Date().getFullYear(); y++) { %>
                                <option value="<%= y %>" <%= selectedYear === y ? 'selected' : '' %>><%= y %></option>
                            <% } %>
                        </select>
                    </div>
                </form>
            </div>

            <!-- Summary Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Income -->
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
                    <p class="text-gray-600 text-sm font-medium">Total Pemasukan</p>
                    <p class="text-2xl font-bold text-green-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(report.income || 0) %>
                    </p>
                </div>

                <!-- Expense -->
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-red-500">
                    <p class="text-gray-600 text-sm font-medium">Total Pengeluaran</p>
                    <p class="text-2xl font-bold text-red-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(report.expense || 0) %>
                    </p>
                </div>

                <!-- Net -->
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-indigo-600">
                    <p class="text-gray-600 text-sm font-medium">Saldo Bersih Tahunan</p>
                    <p class="text-2xl font-bold text-indigo-600 mt-2">
                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format((report.income || 0) - (report.expense || 0)) %>
                    </p>
                </div>
            </div>

            <!-- Monthly Breakdown -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-bold text-gray-800 mb-6">Ringkasan per Bulan</h2>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-gray-50 border-b border-gray-200">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Bulan</th>
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase">Pemasukan</th>
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase">Pengeluaran</th>
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase">Saldo Bersih</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']; %>
                            <% report.monthlyBreakdown.forEach((month, index) => { %>
                                <tr class="border-b border-gray-200 hover:bg-gray-50">
                                    <td class="px-6 py-4 text-sm text-gray-700 font-medium"><%= months[index] %></td>
                                    <td class="px-6 py-4 text-sm text-right text-green-600 font-semibold">
                                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(month.income) %>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-right text-red-600 font-semibold">
                                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(month.expense) %>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-right font-semibold <%= (month.income - month.expense) >= 0 ? 'text-indigo-600' : 'text-red-600' %>">
                                        <%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(month.income - month.expense) %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% } %>
</div>

<%- include('../layout/footer') %>
