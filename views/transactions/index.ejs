<%- include('layout/header', { title: 'Transaksi' }) %>
<%- include('layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row items-center justify-between mb-8">
        <div>
            <h1 class="text-4xl font-bold text-gray-800">Transaksi</h1>
            <p class="text-gray-600">Kelola semua transaksi keuangan Anda</p>
        </div>
        <a href="/transactions/create" class="mt-4 md:mt-0 px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium transition">
            <i class="fas fa-plus mr-2"></i>Transaksi Baru
        </a>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-lg shadow p-6 mb-8">
        <form method="GET" action="/transactions" class="grid grid-cols-1 md:grid-cols-5 gap-4">
            <!-- Date Range -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Dari Tanggal</label>
                <input type="date" name="startDate" value="<%= query.startDate || '' %>"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Hingga Tanggal</label>
                <input type="date" name="endDate" value="<%= query.endDate || '' %>"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
            </div>

            <!-- Asset Filter -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Aset</label>
                <select name="asset_id" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
                    <option value="">Semua Aset</option>
                    <% if (typeof assets !== 'undefined' && assets) { %>
                        <% assets.forEach(asset => { %>
                            <option value="<%= asset.id %>" <%= query.asset_id == asset.id ? 'selected' : '' %>>
                                <%= asset.nama_aset %>
                            </option>
                        <% }); %>
                    <% } %>
                </select>
            </div>

            <!-- Type Filter -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tipe</label>
                <select name="tipe" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none">
                    <option value="">Semua Tipe</option>
                    <option value="income" <%= query.tipe === 'income' ? 'selected' : '' %>>Pemasukan</option>
                    <option value="expense" <%= query.tipe === 'expense' ? 'selected' : '' %>>Pengeluaran</option>
                </select>
            </div>

            <!-- Submit Button -->
            <div class="flex items-end">
                <button type="submit" class="w-full px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium transition">
                    <i class="fas fa-search mr-2"></i>Filter
                </button>
            </div>
        </form>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Tanggal</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Kategori</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Aset</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Tipe</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">Catatan</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase">Jumlah</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-700 uppercase">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof transactions !== 'undefined' && transactions && transactions.length > 0) { %>
                        <% transactions.forEach(tx => { %>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    <%= new Date(tx.tanggal).toLocaleDateString('id-ID') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    <%= tx.Category?.nama_kategori || '-' %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-700">
                                    <%= tx.Asset?.nama_aset || '-' %>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <% if (tx.tipe === 'income') { %>
                                        <span class="inline-block px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-medium">
                                            <i class="fas fa-arrow-up mr-1"></i>Pemasukan
                                        </span>
                                    <% } else { %>
                                        <span class="inline-block px-3 py-1 bg-red-100 text-red-800 rounded-full text-xs font-medium">
                                            <i class="fas fa-arrow-down mr-1"></i>Pengeluaran
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">
                                    <%= tx.catatan ? tx.catatan.substring(0, 30) + (tx.catatan.length > 30 ? '...' : '') : '-' %>
                                </td>
                                <td class="px-6 py-4 text-sm text-right font-semibold">
                                    <% if (tx.tipe === 'income') { %>
                                        <span class="text-green-600">+<%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(tx.jumlah) %></span>
                                    <% } else { %>
                                        <span class="text-red-600">-<%= new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR' }).format(tx.jumlah) %></span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-center space-x-2">
                                    <a href="/transactions/<%= tx.id %>/edit" class="inline-block text-amber-600 hover:text-amber-700">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button onclick="deleteTransaction(<%= tx.id %>)" class="inline-block text-red-600 hover:text-red-700">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="px-6 py-8 text-center text-gray-500">
                                Belum ada transaksi
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
        <div class="bg-gradient-to-r from-red-500 to-red-600 px-6 py-4">
            <h2 class="text-xl font-bold text-white">Hapus Transaksi</h2>
        </div>
        <div class="p-6">
            <p class="text-gray-700 mb-6">Apakah Anda yakin ingin menghapus transaksi ini? Tindakan ini tidak dapat dibatalkan.</p>
            <div class="flex justify-end space-x-3">
                <button onclick="closeDeleteModal()" class="px-4 py-2 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300">
                    Batal
                </button>
                <form id="deleteForm" method="POST" style="display: inline;">
                    <button type="submit" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg">
                        Hapus
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function deleteTransaction(id) {
        document.getElementById('deleteForm').action = '/transactions/' + id + '/delete';
        document.getElementById('deleteModal').classList.remove('hidden');
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
    }
</script>

<%- include('layout/footer') %>
