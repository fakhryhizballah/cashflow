<%- include('../layout/header', { title: isEdit ? 'Edit Aset' : 'Buat Aset' }) %>
<%- include('../layout/navbar') %>

<!-- Main Content -->
<div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800">
            <% if (isEdit) { %>
                Edit Aset
            <% } else { %>
                Buat Aset Baru
            <% } %>
        </h1>
        <p class="text-gray-600">
            <% if (isEdit) { %>
                Ubah data aset
            <% } else { %>
                Tambahkan aset keuangan baru
            <% } %>
        </p>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-lg shadow p-8 max-w-2xl mx-auto" id="formContainer">

    </div>
</div>

<%- include('../layout/footer') %>
