<%- include('layout/header', { title: 'Login' }) %>

<!-- Login Container -->
<div class="min-h-screen bg-gradient-to-br from-indigo-500 to-indigo-600 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <!-- Card -->
        <div class="bg-white rounded-lg shadow-xl p-8">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-indigo-600 mb-2">
                    <i class="fas fa-wallet mr-2"></i>CashFlow
                </h1>
                <p class="text-gray-600">Kelola Keuangan Anda dengan Mudah</p>
            </div>

            <!-- Error Alert -->
            <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
                <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
                    <p class="text-red-600 text-sm font-medium"><i class="fas fa-exclamation-circle mr-2"></i>Login Gagal</p>
                    <% errors.forEach(error => { %>
                        <p class="text-red-500 text-xs mt-1"><%= error.message %></p>
                    <% }); %>
                </div>
            <% } %>

            <!-- Login Form -->
            <form action="/api/auth/login" method="POST" class="space-y-4">
                <!-- Email -->
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" id="email" name="email" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none"
                        placeholder="your@email.com">
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" id="password" name="password" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none"
                        placeholder="••••••••">
                </div>

                <!-- Remember Me -->
                <div class="flex items-center">
                    <input type="checkbox" id="remember" name="remember" class="rounded">
                    <label for="remember" class="ml-2 text-sm text-gray-600">Ingat saya</label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 rounded-lg transition">
                    <i class="fas fa-sign-in-alt mr-2"></i>Login
                </button>
            </form>

            <!-- Divider -->
            <div class="relative my-6">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-300"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-2 bg-white text-gray-500">Atau</span>
                </div>
            </div>

            <!-- Register Link -->
            <p class="text-center text-gray-600 text-sm">
                Belum punya akun?
                <a href="/auth/register" class="text-indigo-600 hover:text-indigo-700 font-medium">Daftar di sini</a>
            </p>
        </div>

        <!-- Footer -->
        <div class="text-center mt-8 text-gray-400 text-sm">
            <p>&copy; 2026 Cash Flow Management. All rights reserved.</p>
        </div>
    </div>
</div>

<%- include('layout/footer') %>
